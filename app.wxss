/* app.wxss - 全局样式 */

/* 主题变量 */
page {
  --primary-color: #4A90D9;
  --secondary-color: #5CB3CC;
  --accent-color: #FF6B6B;
  --text-color: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  --border-color: #E8E8E8;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--bg-color);
  color: var(--text-color);
  font-size: 28rpx;
}

/* 通用容器 */
.container {
  padding: 30rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
}

/* 输入框样式 */
.input-wrapper {
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 30rpx;
}

.input-wrapper input {
  font-size: 32rpx;
  color: var(--text-color);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 30rpx 0;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: var(--text-light);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}
