/* pages/result/result.wxss */

.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #F5F7FA;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
  padding: 0 60rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #4A90D9, #5CB3CC);
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

/* 收藏列表 */
.favorite-list {
  padding-bottom: 100rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.list-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.list-count {
  font-size: 26rpx;
  color: #999;
}

/* 名字卡片 */
.name-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.name-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.name-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.name-main {
  display: flex;
  align-items: baseline;
}

.name-surname {
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
}

.name-given {
  font-size: 44rpx;
  font-weight: 600;
  color: #4A90D9;
}

.name-score {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #FF9500;
}

.score-star {
  margin-right: 6rpx;
}

.name-details {
  margin-bottom: 16rpx;
}

.meaning-item {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.meaning-char {
  color: #4A90D9;
  font-weight: 500;
  margin-right: 10rpx;
}

.meaning-text {
  color: #666;
}

.name-wuxing {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.wuxing-label {
  color: #999;
  margin-right: 10rpx;
}

.wuxing-tags {
  display: flex;
  gap: 10rpx;
}

.wuxing-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.wuxing-tag.金 { background: #FFF7E6; color: #D48806; }
.wuxing-tag.木 { background: #E6F7E6; color: #52C41A; }
.wuxing-tag.水 { background: #E6F4FF; color: #1890FF; }
.wuxing-tag.火 { background: #FFF1F0; color: #FF4D4F; }
.wuxing-tag.土 { background: #F5F5DC; color: #8B7355; }

.name-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.name-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.action-btn.danger {
  background: #FFF1F0;
  color: #FF4D4F;
}

/* 清空按钮 */
.clear-all {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
  margin-top: 30rpx;
}
