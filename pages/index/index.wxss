/* pages/index/index.wxss */

.container {
  padding: 30rpx;
  padding-bottom: 100rpx;
  background: linear-gradient(180deg, #E8F4FD 0%, #F5F7FA 100%);
  min-height: 100vh;
}

/* 收藏入口 */
.fav-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #FFE4E4, #FFF0F0);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #FF4D4F;
}

.fav-arrow {
  font-size: 32rpx;
  opacity: 0.6;
}

/* 头部 */
.header {
  text-align: center;
  padding: 40rpx 0;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #666;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  color: #333;
}

.label-icon {
  margin-right: 10rpx;
}

.label-optional {
  font-size: 24rpx;
  color: #999;
  margin-left: 10rpx;
}

.form-input {
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  font-size: 32rpx;
}

.surname-info {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #FFF7E6;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #D48806;
}

/* 性别选择 */
.gender-selector {
  display: flex;
  gap: 20rpx;
}

.gender-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.gender-option.active {
  background: #E6F4FF;
  border-color: #4A90D9;
}

.gender-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

/* 日期选择 */
.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  font-size: 32rpx;
}

.date-picker.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 36rpx;
  color: #999;
}

/* 数量选择 */
.count-selector {
  display: flex;
  gap: 20rpx;
}

.count-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}

.count-option.active {
  background: #E6F4FF;
  border-color: #4A90D9;
  color: #4A90D9;
}

/* 生成按钮 */
.generate-btn {
  width: 100%;
  background: linear-gradient(135deg, #4A90D9, #5CB3CC);
  color: #fff;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 34rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 217, 0.3);
}

.generate-btn.disabled {
  opacity: 0.5;
  box-shadow: none;
}

/* 结果区域 */
.result-section {
  margin-top: 40rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.result-tip {
  font-size: 24rpx;
  color: #999;
}

/* 名字卡片 */
.name-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.name-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.name-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.name-rank {
  font-size: 24rpx;
  color: #999;
  background: #F5F7FA;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.name-score {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #FF9500;
}

.score-star {
  margin-right: 6rpx;
}

.name-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.name-surname {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
}

.name-given {
  font-size: 48rpx;
  font-weight: 600;
  color: #4A90D9;
}

.name-details {
  margin-bottom: 16rpx;
}

.meaning-item {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.meaning-char {
  color: #4A90D9;
  font-weight: 500;
  margin-right: 10rpx;
}

.meaning-text {
  color: #666;
}

.name-wuxing {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 24rpx;
}

.wuxing-label {
  color: #999;
  margin-right: 10rpx;
}

.wuxing-tags {
  display: flex;
  gap: 10rpx;
}

.wuxing-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.wuxing-tag.金 { background: #FFF7E6; color: #D48806; }
.wuxing-tag.木 { background: #E6F7E6; color: #52C41A; }
.wuxing-tag.水 { background: #E6F4FF; color: #1890FF; }
.wuxing-tag.火 { background: #FFF1F0; color: #FF4D4F; }
.wuxing-tag.土 { background: #F5F5DC; color: #8B7355; }

.name-actions {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.action-btn.favorited {
  background: #FFF1F0;
  color: #FF4D4F;
}

/* 五行提示 */
.wuxing-tip {
  display: flex;
  align-items: center;
  background: #E6F4FF;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-top: 30rpx;
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
}
